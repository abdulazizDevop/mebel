# Copy to .env and fill in real values. Never commit .env.

# SQLite for local dev. Switch to postgresql+psycopg2://user:pass@host:5432/dbname for prod.
DATABASE_URL=sqlite:///./dev.db

# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# Comma-separated list of frontend origins allowed to call the API.
# Dev:  http://localhost:5173,http://127.0.0.1:5173
# Prod: https://rooomebel.ru,https://www.rooomebel.ru
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# First admin bootstrapped by `python -m app.seed`. Change immediately after first login.
BOOTSTRAP_ADMIN_NAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin

# VAPID keypair for Web Push. Generate with `python -m app.gen_vapid` and paste here.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com

# S3 (or any S3-compatible store: Wasabi, Backblaze B2, MinIO).
# When `S3_BUCKET` is empty the backend falls back to local disk under
# `backend/uploads/` and serves them at /static/uploads/...  — fine for dev,
# never for prod.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT_URL=             # leave empty for AWS; set for non-AWS S3
S3_PUBLIC_URL_PREFIX=        # e.g. https://cdn.rooomebel.uz — empty = canonical S3 host
UPLOAD_MAX_BYTES=10485760    # 10 MB
